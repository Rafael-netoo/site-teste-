cti:PPG a owl:Class ;
    oml:type oml:Concept ;
    rdfs:subClassOf cti:PPG,
        owl:Thing .

cti:Docente a owl:Class ;
    oml:type oml:Concept ;
    rdfs:subClassOf cti:Docente,
        owl:Thing .

owl:Thing a owl:Class .

[] a owl:AllDisjointClasses ;
    owl:members ( cti:Docente cti:ICT cti:PPG cti:Sediacao cti:Vinculacao ) .

[] a swrl:Imp ;
    rdfs:label "sediado_em derivation" ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 <urn:swrl:var#r> ;
                    swrl:classPredicate cti:Sediacao ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#r> ;
                            swrl:argument2 <urn:swrl:var#s> ;
                            swrl:propertyPredicate oml:hasSource ] ;
                    rdf:rest [ a swrl:AtomList ;
                            rdf:first [ a swrl:IndividualPropertyAtom ;
                                    swrl:argument1 <urn:swrl:var#r> ;
                                    swrl:argument2 <urn:swrl:var#t> ;
                                    swrl:propertyPredicate oml:hasTarget ] ;
                            rdf:rest () ] ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#s> ;
                    swrl:argument2 <urn:swrl:var#t> ;
                    swrl:propertyPredicate cti:sediado_em ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    rdfs:label "vinculado_a derivation" ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 <urn:swrl:var#r> ;
                    swrl:classPredicate cti:Vinculacao ] ;
            rdf:rest [ a swrl:AtomList ;
                    rdf:first [ a swrl:IndividualPropertyAtom ;
                            swrl:argument1 <urn:swrl:var#r> ;
                            swrl:argument2 <urn:swrl:var#s> ;
                            swrl:propertyPredicate oml:hasSource ] ;
                    rdf:rest [ a swrl:AtomList ;
                            rdf:first [ a swrl:IndividualPropertyAtom ;
                                    swrl:argument1 <urn:swrl:var#r> ;
                                    swrl:argument2 <urn:swrl:var#t> ;
                                    swrl:propertyPredicate oml:hasTarget ] ;
                            rdf:rest () ] ] ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 <urn:swrl:var#s> ;
                    swrl:argument2 <urn:swrl:var#t> ;
                    swrl:propertyPredicate cti:vinculado_a ] ;
            rdf:rest () ] .

